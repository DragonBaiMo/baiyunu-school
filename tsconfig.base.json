{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "baseUrl": ".",
    "paths": {
      "@bynu/auth": ["packages/auth/src"],
      "@bynu/auth/*": ["packages/auth/src/*"],
      "@bynu/cache": ["packages/cache/src"],
      "@bynu/cache/*": ["packages/cache/src/*"],
      "@bynu/config": ["packages/config/src"],
      "@bynu/config/*": ["packages/config/src/*"],
      "@bynu/contracts": ["packages/contracts/src"],
      "@bynu/contracts/*": ["packages/contracts/src/*"],
      "@bynu/db": ["packages/db/src"],
      "@bynu/db/*": ["packages/db/src/*"],
      "@bynu/design-tokens": ["packages/design-tokens/src"],
      "@bynu/design-tokens/*": ["packages/design-tokens/src/*"],
      "@bynu/domain": ["packages/domain/src"],
      "@bynu/domain/*": ["packages/domain/src/*"],
      "@bynu/logger": ["packages/logger/src"],
      "@bynu/logger/*": ["packages/logger/src/*"],
      "@bynu/test-utils": ["packages/test-utils/src"],
      "@bynu/test-utils/*": ["packages/test-utils/src/*"],
      "@bynu/ui": ["packages/ui/src"],
      "@bynu/ui/*": ["packages/ui/src/*"]
    }
  },
  "exclude": ["**/node_modules", "**/dist", "**/build"]
}
