<view class="container">
  <button class="btn {{showForm ? 'btn-ghost' : ''}}" bindtap="toggleForm">
    {{showForm ? '取消' : '+ 发布新活动'}}
  </button>

  <view wx:if="{{showForm}}" class="card" style="margin-top:24rpx;">
    <view class="label">活动名称</view>
    <input class="input" value="{{form.title}}" data-k="title" bindinput="onF" placeholder="请输入标题" />
    <view class="label" style="margin-top:16rpx;">日期</view>
    <input class="input" value="{{form.date}}" data-k="date" bindinput="onF" placeholder="YYYY-MM-DD" />
    <view class="label" style="margin-top:16rpx;">地点</view>
    <input class="input" value="{{form.location}}" data-k="location" bindinput="onF" placeholder="活动地点" />
    <view class="label" style="margin-top:16rpx;">类别</view>
    <picker range="{{categories}}" bindchange="pickCat">
      <view class="input">{{form.category}} ▾</view>
    </picker>
    <view class="label" style="margin-top:16rpx;">名额</view>
    <input class="input" type="number" value="{{form.capacity}}" data-k="capacity" bindinput="onF" />
    <view class="label" style="margin-top:16rpx;">介绍</view>
    <textarea class="input" value="{{form.description}}" data-k="description" bindinput="onF" placeholder="活动介绍" style="height:160rpx;"></textarea>
    <button class="btn" bindtap="create" style="margin-top:24rpx;">发布活动</button>
  </view>

  <view class="section-title">现有活动（{{list.length}}）</view>
  <view class="card" wx:for="{{list}}" wx:key="id">
    <view class="row-between">
      <view class="title" style="font-size:30rpx;">{{item.title}}</view>
      <view class="tag">{{item.category}}</view>
    </view>
    <view class="text-sub text-small">📆 {{item.date}} · 📍 {{item.location}}</view>
    <view class="text-sub text-small">报名 {{item.enrolled}}/{{item.capacity}}</view>
    <button class="mini-btn ghost" data-id="{{item.id}}" bindtap="remove" style="margin-top:16rpx;">删除</button>
  </view>
</view>
