<view class="container">
  <scroll-view scroll-x class="cat-scroll">
    <view wx:for="{{categories}}" wx:key="*this"
      class="cat-chip {{(filter==='all'&&item==='全部') || filter===item ? 'active' : ''}}"
      data-cat="{{item==='全部' ? 'all' : item}}" bindtap="filterTap">{{item}}</view>
  </scroll-view>

  <view wx:for="{{list}}" wx:key="id" wx:if="{{filter==='all' || item.category===filter}}"
    class="card" bindtap="open" data-id="{{item.id}}">
    <view class="row-between">
      <view class="tag">{{item.category}}</view>
      <view class="tag tag-accent" wx:if="{{item.coverTag}}">{{item.coverTag}}</view>
    </view>
    <view class="title" style="font-size:32rpx;margin-top:12rpx;">{{item.title}}</view>
    <view class="text-sub text-small">📍 {{item.location}}</view>
    <view class="text-sub text-small">📆 {{item.date}}</view>
    <view class="progress-row">
      <view class="progress-bar">
        <view class="progress-fill" style="width:{{item.enrolled/item.capacity*100}}%;"></view>
      </view>
      <view class="text-small text-sub" style="margin-left:12rpx;">{{item.enrolled}}/{{item.capacity}}</view>
    </view>
  </view>

  <view wx:if="{{!list.length}}" class="empty">暂无活动</view>
  <view class="safe-bottom"></view>
</view>

<view class="bottom-nav">
  <view class="nav-item" bindtap="goHome"><text class="icon">🏠</text>首页</view>
  <view class="nav-item active"><text class="icon">📅</text>活动</view>
  <view class="nav-item" bindtap="goDonate"><text class="icon">💝</text>捐赠</view>
  <view class="nav-item" bindtap="goMe"><text class="icon">👤</text>我的</view>
</view>
