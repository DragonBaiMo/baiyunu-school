.cat-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}
.cat-chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  background: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #6B7280;
  border: 2rpx solid #E5E7EB;
}
.cat-chip.active {
  background: #0F2C5C;
  color: #fff;
  border-color: #0F2C5C;
}
.progress-row { display: flex; align-items: center; margin-top: 16rpx; }
.progress-bar { flex: 1; height: 10rpx; background: #EEF2FB; border-radius: 6rpx; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #0F2C5C, #1E4B9E); }
