<view class="container">
  <button class="btn {{showForm ? 'btn-ghost' : ''}}" bindtap="toggleForm">
    {{showForm ? '取消' : '+ 发布新资讯'}}
  </button>

  <view wx:if="{{showForm}}" class="card" style="margin-top:24rpx;">
    <view class="label">标题</view>
    <input class="input" value="{{form.title}}" data-k="title" bindinput="onF" />
    <view class="label" style="margin-top:16rpx;">类别</view>
    <picker range="{{categories}}" bindchange="pickCat">
      <view class="input">{{form.category}} ▾</view>
    </picker>
    <view class="label" style="margin-top:16rpx;">摘要</view>
    <textarea class="input" value="{{form.summary}}" data-k="summary" bindinput="onF" style="height:160rpx;"></textarea>
    <button class="btn" bindtap="create" style="margin-top:24rpx;">发布</button>
  </view>

  <view class="section-title">已发布（{{list.length}}）</view>
  <view class="card" wx:for="{{list}}" wx:key="id">
    <view class="row-between">
      <view class="tag">{{item.category}}</view>
      <view class="text-sub text-small">{{item.date}}</view>
    </view>
    <view class="title" style="font-size:30rpx;margin-top:10rpx;">{{item.title}}</view>
    <view class="text-sub text-small">{{item.summary}}</view>
    <button class="mini-btn ghost" data-id="{{item.id}}" bindtap="remove" style="margin-top:16rpx;">删除</button>
  </view>
</view>
