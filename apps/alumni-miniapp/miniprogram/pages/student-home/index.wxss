.hero-card {
  background: linear-gradient(135deg, #0F2C5C 0%, #1E4B9E 100%);
  color: #fff;
  border-radius: 20rpx;
  padding: 36rpx 28rpx;
  margin-bottom: 32rpx;
}
.welcome-row { display: flex; justify-content: space-between; align-items: center; }
.welcome { font-size: 36rpx; font-weight: 600; }
.welcome-sub { font-size: 24rpx; color: rgba(255,255,255,0.75); margin-top: 6rpx; }
.avatar {
  width: 88rpx; height: 88rpx; border-radius: 50%;
  background: #D4AF37; color: #2C1810;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; font-weight: 600;
}
.stats-row {
  display: flex; justify-content: space-around;
  margin-top: 32rpx; padding-top: 24rpx;
  border-top: 1rpx solid rgba(255,255,255,0.15);
}
.stat-item { text-align: center; }
.stat-num { font-size: 40rpx; font-weight: 700; color: #D4AF37; }
.stat-label { font-size: 22rpx; color: rgba(255,255,255,0.8); margin-top: 4rpx; }

.quick-grid {
  display: flex; justify-content: space-between;
  background: #fff; border-radius: 16rpx;
  padding: 28rpx 8rpx; margin-bottom: 32rpx;
}
.quick-item { flex: 1; text-align: center; }
.quick-icon {
  width: 80rpx; height: 80rpx; border-radius: 16rpx;
  margin: 0 auto 12rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx;
}
.quick-text { font-size: 24rpx; color: #1A1F2E; }

.section-header {
  display: flex; justify-content: space-between; align-items: baseline;
  margin: 16rpx 4rpx 16rpx;
}
.section-title { font-size: 32rpx; font-weight: 600; color: #1A1F2E; }

.news-title { font-size: 30rpx; font-weight: 500; color: #1A1F2E; margin: 10rpx 0 6rpx; }

.progress-row { display: flex; align-items: center; margin-top: 14rpx; }
.progress-bar {
  flex: 1; height: 10rpx; background: #EEF2FB; border-radius: 6rpx; overflow: hidden;
}
.progress-fill { height: 100%; background: linear-gradient(90deg, #0F2C5C, #1E4B9E); }
