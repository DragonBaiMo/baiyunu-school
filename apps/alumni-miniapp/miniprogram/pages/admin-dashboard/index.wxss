.admin-hero {
  background: linear-gradient(135deg, #0F2C5C 0%, #1E4B9E 100%);
  border-radius: 20rpx;
  padding: 36rpx 28rpx;
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 24rpx;
}
.logout-btn {
  padding: 10rpx 22rpx;
  border: 2rpx solid rgba(255,255,255,0.4);
  color: #fff; border-radius: 40rpx; font-size: 24rpx;
}
.kpi-grid {
  display: flex; flex-wrap: wrap; gap: 16rpx;
  margin-bottom: 28rpx;
}
.kpi {
  flex: 1 1 calc(50% - 8rpx);
  background: #fff; border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(15,44,92,0.06);
}
.kpi-label { font-size: 24rpx; color: #6B7280; }
.kpi-num { font-size: 48rpx; font-weight: 700; color: #0F2C5C; margin-top: 6rpx; }
.kpi-extra { font-size: 22rpx; color: #D4AF37; margin-top: 4rpx; }

.section-title { font-size: 30rpx; font-weight: 600; margin: 16rpx 4rpx; }
.module-card {
  background: #fff; border-radius: 16rpx;
  padding: 28rpx; margin-bottom: 16rpx;
  display: flex; align-items: center;
  position: relative;
}
.module-icon {
  width: 88rpx; height: 88rpx; border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx; margin-right: 24rpx;
}
.module-body { flex: 1; }
.module-title { font-size: 30rpx; font-weight: 600; }
.module-desc { font-size: 24rpx; color: #6B7280; margin-top: 4rpx; }
.module-arrow { color: #B0B7C3; font-size: 44rpx; }
.badge-red {
  position: absolute; top: 22rpx; right: 60rpx;
  min-width: 36rpx; height: 36rpx; padding: 0 10rpx;
  background: #EF4444; color: #fff; font-size: 22rpx;
  border-radius: 18rpx; display: flex; align-items: center; justify-content: center;
}
