.info-row {
  display: flex; justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F1F3F7;
  font-size: 28rpx;
}
.info-row:last-child { border-bottom: none; }
.info-label { color: #6B7280; }
.progress-row { display: flex; align-items: center; }
.progress-bar { flex: 1; height: 12rpx; background: #EEF2FB; border-radius: 6rpx; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #0F2C5C, #1E4B9E); }
