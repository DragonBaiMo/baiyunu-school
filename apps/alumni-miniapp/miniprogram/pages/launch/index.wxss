.launch {
  min-height: 100vh;
  background: linear-gradient(180deg, #0F2C5C 0%, #1E4B9E 45%, #F5F7FA 45%, #F5F7FA 100%);
  padding: 120rpx 40rpx 60rpx;
  box-sizing: border-box;
}
.hero { color: #fff; margin-bottom: 80rpx; }
.badge {
  display: inline-block;
  padding: 6rpx 18rpx;
  border: 2rpx solid rgba(212,175,55,0.6);
  color: #D4AF37;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  border-radius: 4rpx;
  margin-bottom: 24rpx;
}
.hero-title { font-size: 64rpx; font-weight: 700; line-height: 1.2; white-space: pre-line; }
.hero-sub { margin-top: 20rpx; font-size: 28rpx; color: rgba(255,255,255,0.82); }

.role-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(15,44,92,0.12);
}
.role-icon {
  width: 88rpx; height: 88rpx; border-radius: 20rpx;
  background: #0F2C5C; color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx;
  margin-right: 24rpx;
}
.role-body { flex: 1; }
.role-title { font-size: 32rpx; font-weight: 600; color: #1A1F2E; }
.role-desc { font-size: 24rpx; color: #6B7280; margin-top: 6rpx; }
.role-arrow { color: #B0B7C3; font-size: 48rpx; }
.footer { text-align: center; color: #6B7280; font-size: 22rpx; margin-top: 60rpx; }
