/* 全局样式：白云大学校友平台 */
page {
  --color-primary: #0F2C5C;
  --color-primary-light: #1E4B9E;
  --color-accent: #D4AF37;
  --color-bg: #F5F7FA;
  --color-surface: #FFFFFF;
  --color-text: #1A1F2E;
  --color-text-sub: #6B7280;
  --color-border: #E5E7EB;
  --color-success: #10B981;
  --color-danger: #EF4444;
  background: var(--color-bg);
  color: var(--color-text);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

.container {
  padding: 32rpx 28rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

.card {
  background: var(--color-surface);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(15, 44, 92, 0.06);
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: var(--color-text-sub);
}

.btn {
  width: 100%;
  background: var(--color-primary);
  color: #fff;
  border-radius: 12rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 30rpx;
  border: none;
}
.btn[disabled] {
  background: #B0B7C3;
  color: #fff;
}
.btn::after { border: none; }

.btn-ghost {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}

.btn-accent { background: var(--color-accent); color: #2C1810; }

.input {
  width: 100%;
  background: #F5F7FA;
  border-radius: 10rpx;
  padding: 22rpx 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  border: 2rpx solid transparent;
}
.input:focus { border-color: var(--color-primary); background: #fff; }

.row { display: flex; align-items: center; }
.row-between { display: flex; align-items: center; justify-content: space-between; }
.gap-s { gap: 12rpx; }
.gap-m { gap: 24rpx; }

.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: rgba(15, 44, 92, 0.08);
  color: var(--color-primary);
}
.tag-accent { background: rgba(212, 175, 55, 0.18); color: #8B6F14; }
.tag-success { background: rgba(16, 185, 129, 0.12); color: var(--color-success); }
.tag-danger { background: rgba(239, 68, 68, 0.12); color: var(--color-danger); }

.empty {
  padding: 80rpx 0;
  text-align: center;
  color: var(--color-text-sub);
  font-size: 26rpx;
}

.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: 24rpx 0;
}

.text-primary { color: var(--color-primary); }
.text-accent { color: var(--color-accent); }
.text-sub { color: var(--color-text-sub); }
.text-small { font-size: 24rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 40rpx; font-weight: 600; }

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-top: 1rpx solid var(--color-border);
  display: flex;
  padding: 12rpx 0 24rpx;
  z-index: 99;
}
.bottom-nav .nav-item {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-sub);
}
.bottom-nav .nav-item.active { color: var(--color-primary); font-weight: 600; }
.bottom-nav .nav-item .icon { font-size: 40rpx; display: block; margin-bottom: 4rpx; }

.safe-bottom { height: 140rpx; }
