{
  "name": "@bynu/design-tokens",
  "version": "0.1.0",
  "private": true,
  "description": "Design tokens 单一事实源：CSS vars / Tailwind preset / 小程序 wxss / JSON",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./tailwind-preset": "./dist/tailwind.preset.js",
    "./tokens.css": "./dist/tokens.css",
    "./miniapp.wxss": "./dist/miniapp.wxss",
    "./tokens.json": "./dist/tokens.json"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsx src/build.ts",
    "verify": "tsx scripts/verify.ts",
    "dev": "tsx src/build.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "rimraf": "6.0.1",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
