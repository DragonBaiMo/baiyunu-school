{
  "name": "@bynu/adapters",
  "version": "0.1.0-alpha",
  "private": true,
  "description": "6 个外部系统 Adapter 的汇总壳（interface + mock + factory）",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./payment": "./payment/src/index.ts",
    "./edu-system": "./edu-system/src/index.ts",
    "./stu-affairs": "./stu-affairs/src/index.ts",
    "./access-control": "./access-control/src/index.ts",
    "./chaoxing-sso": "./chaoxing-sso/src/index.ts",
    "./e-sign": "./e-sign/src/index.ts"
  },
  "scripts": {
    "build": "pnpm -r --filter \"@bynu/adapter-*\" build",
    "test": "pnpm -r --filter \"@bynu/adapter-*\" test",
    "typecheck": "pnpm -r --filter \"@bynu/adapter-*\" typecheck",
    "lint": "pnpm -r --filter \"@bynu/adapter-*\" lint"
  },
  "dependencies": {
    "@bynu/adapter-payment": "workspace:*",
    "@bynu/adapter-edu-system": "workspace:*",
    "@bynu/adapter-stu-affairs": "workspace:*",
    "@bynu/adapter-access-control": "workspace:*",
    "@bynu/adapter-chaoxing-sso": "workspace:*",
    "@bynu/adapter-e-sign": "workspace:*"
  },
  "devDependencies": {
    "typescript": "5.6.3"
  }
}
