    "gen": "tsx ../../tools/codegen/gen.ts"
  },
  "dependencies": {
    "zod": "3.23.8"
  },
  "devDependencies": {
    "openapi-typescript": "7.4.4",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
