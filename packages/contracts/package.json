{
  "name": "@bynu/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./openapi/*": "./openapi/*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
