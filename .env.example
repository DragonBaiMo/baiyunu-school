# ========================================
# 白云学院超星智慧校友服务平台 - 环境变量范例
# 使用方式：复制为 .env 后根据实际环境填入
# 禁止在仓库中提交真实机密
# ========================================

NODE_ENV=development

# 数据库：dev 默认嵌入式 pglite；生产切换 postgres://
DATABASE_URL=pglite:./.data/pg

# 缓存：dev 默认 ioredis-mock；生产切换 redis://host:port
REDIS_URL=mock://local

# JWT 与加密
JWT_SECRET=dev-only-replace-in-prod-change-me-to-strong-secret
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Adapter 切换标志
PAYMENT_PROVIDER=mock
EDU_PROVIDER=mock
STU_PROVIDER=mock
ACCESS_PROVIDER=mock
ACL_PROVIDER=mock
CHAOXING_PROVIDER=mock
ESIGN_PROVIDER=mock

# 端口
PORT_BFF=3000
PORT_SERVER=3001
PORT_ADMIN_WEB=5173
PORT_ALUMNI_H5=5174

# 日志
LOG_LEVEL=info
